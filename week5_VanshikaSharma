      "source": [
        "# ✍️ Text Generation Function\n",
        "This function predicts the next word repeatedly to generate a sentence."
      ],
      "id": "n5cGMjUNMLvD"
    },
    {
      "cell_type": "code",
      "execution_count": 12,
      "metadata": {
        "id": "uPCbwIwbMLvD"
      },
      "outputs": [],
      "source": [
        "def generate_text(model, seed_text, next_words=10):\n",
        "    for _ in range(next_words):\n",
        "        token_list = tokenizer.texts_to_sequences([seed_text])[0]\n",
        "        token_list = pad_sequences([token_list], maxlen=max_len-1, padding='pre')\n",
        "        predicted = np.argmax(model.predict(token_list, verbose=0), axis=-1)[0]\n",
        "\n",
        "        output_word = \"\"\n",
        "        for word, index in tokenizer.word_index.items():\n",
        "            if index == predicted:\n",
        "                output_word = word\n",
        "                break\n",
        "        seed_text += \" \" + output_word\n",
        "    return seed_text"
      ],
      "id": "uPCbwIwbMLvD"
    },
