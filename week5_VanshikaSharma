      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "LSTM training completed\n"
          ]
        }
      ],
      "source": [
        "lstm_model = Sequential([\n",
        "    Embedding(total_words, 64),\n",
        "    LSTM(128),\n",
        "    Dense(total_words, activation='softmax')\n",
        "])\n",
        "\n",
        "lstm_model.compile(loss='sparse_categorical_crossentropy',\n",
        "                   optimizer='adam',\n",
        "                   metrics=['accuracy'])\n",
        "\n",
        "lstm_history = lstm_model.fit(X, y, epochs=200, verbose=0)\n",
        "print(\"LSTM training completed\")"
      ],
      "id": "DdVsEJAzMLvC"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "ivb2oNZ8MLvC"
      },
      "source": [
        "# ⚡ Model 3: GRU\n",
        "GRU uses **reset + update gates**.\n",
        "It is computationally faster than LSTM and often gives similar results."
      ],
      "id": "ivb2oNZ8MLvC"
    },
    {
      "cell_type": "code",
      "execution_count": 10,
      "metadata": {
        "id": "jd9sW7LaMLvC",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "1ca94d2a-2554-4a33-9407-cbb69e67d6d2"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "GRU training completed\n"
          ]
        }
      ],
      "source": [
        "gru_model = Sequential([\n",
        "    Embedding(total_words, 32, input_length=max_len-1),\n",
        "    GRU(64),\n",
        "    Dense(total_words, activation='softmax')\n",
        "])\n",
        "\n",
        "gru_model.compile(loss='sparse_categorical_crossentropy',\n",
        "                  optimizer='adam',\n",
        "                  metrics=['accuracy'])\n",
        "\n",
        "gru_history = gru_model.fit(X, y, epochs=100, verbose=0)\n",
        "print(\"GRU training completed\")"
      ],
      "id": "jd9sW7LaMLvC"
    },
